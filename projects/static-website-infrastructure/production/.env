# Project Configuration
PROJECT_NAME=static-website-infrastructure
ENVIRONMENT=Production
GITHUB_REPOSITORY=stabbotco1/terraform-aws-static-website-infrastructure

# AWS Configuration - Fixed to us-east-1 for deployment role control plane
AWS_REGION=us-east-1

# Foundation-aligned tags
TF_VAR_project_name=static-website-infrastructure
TF_VAR_environment=Production
TF_VAR_github_repository=stabbotco1/terraform-aws-static-website-infrastructure
TF_VAR_aws_region=us-east-1
TF_VAR_owner="Platform Team"
TF_VAR_managed_by="Terraform"
TF_VAR_deployment_id="Default"

# Backend Configuration
BACKEND_KEY=deployment-roles/stabbotco1-terraform-aws-static-website-infrastructure/terraform.tfstate
